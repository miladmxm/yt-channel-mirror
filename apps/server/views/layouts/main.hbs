<html dir="rtl" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>

    <meta name="description" content="FullstacksJS Videos" />
    <meta property="og:title" content="{{title}}" />
    <meta property="og:description" content="FullstacksJS Videos" />
    <meta
      property="og:image"
      content="https://videos.fullstacksjs.com/static/og.png"
    />
    <meta property="og:image:alt" content="FullstacksJS Videos" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{title}}" />
    <meta name="twitter:description" content="FullstacksJS Videos" />
    <meta
      name="twitter:image"
      content="https://videos.fullstacksjs.com/static/og.png"
    />
    <meta name="twitter:image:alt" content="FullstacksJS Videos" />

    <link rel="icon" href="/static/favicon.ico" />
    <link
      rel="apple-touch-icon"
      href="/static/apple-touch-icon.png"
      sizes="180x180"
    />
    <link
      rel="mask-icon"
      href="/static/maskable_icon_512x512.png"
      color="#FFFFFF"
    />
    <link rel="manifest" href="/static/manifest.webmanifest" />

    <link rel="stylesheet" href="/static/fonts.css" />
    <link rel="stylesheet" href="/static/styles.css" />
  </head>

  <body>
    <div class="page">
      <header class="header">
        <a class="brand" href="/">
          <span class="brand-mark">▶</span>
          <h1>FullstacksJS</h1>
          <p class="sub">{{count}} videos available offline</p>
        </a>
        <form class="controls" method="get" action="/">
          <input
            class="search"
            type="search"
            name="q"
            placeholder="Search videos…"
            value="{{query}}"
          />
          <button class="button" type="submit">Search</button>
        </form>
      </header>
      <nav class="navigation">
        <ul>
          <li><a href="/">Videos</a></li>
          <li><a href="/playlists">Playlists</a></li>
        </ul>
      </nav>
      {{{body}}}
    </div>
  </body>
</html>
